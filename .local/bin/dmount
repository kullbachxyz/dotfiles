#!/bin/sh
# dmount - mount USB drives using dmenu

# List unmounted partitions on removable/USB devices only (sda, sdb, etc. — not nvme)
DRIVES=$(lsblk -rno NAME,TYPE,SIZE,MOUNTPOINT | awk '$2=="part" && $4=="" && $1~/^sd/ {printf "/dev/%s (%s)\n", $1, $3}')
[ -z "$DRIVES" ] && notify-send "dmount" "No unmounted drives found." && exit 1

# Pick a drive
CHOSEN=$(echo "$DRIVES" | dmenu -p "Mount drive:")
[ -z "$CHOSEN" ] && exit 0

# Extract just the device path
DRIVE=$(echo "$CHOSEN" | awk '{print $1}')

# Pick or enter a mount point
MOUNTPOINT=$(echo "/mnt/usb" | dmenu -p "Mount point:")
[ -z "$MOUNTPOINT" ] && exit 0

# Ask for sudo password using -P (masked input)
PASSWORD=$(echo "" | dmenu -P -p "sudo password:")
[ -z "$PASSWORD" ] && exit 0

# Create mount point if needed and mount
echo "$PASSWORD" | sudo -S mkdir -p "$MOUNTPOINT" 2>/dev/null
echo "$PASSWORD" | sudo -S mount "$DRIVE" "$MOUNTPOINT" 2>/tmp/dmount_err

if [ $? -eq 0 ]; then
    notify-send "dmount" "Mounted $DRIVE at $MOUNTPOINT"
else
    notify-send "dmount" "Failed to mount $DRIVE: $(cat /tmp/dmount_err)"
fi
