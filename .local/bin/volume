#!/bin/bash

DUNSTRC="$HOME/.config/dunst/dunstrc"

# Extract border color from urgency_normal
HL_COLOR=$(grep -A5 "\[urgency_normal\]" "$DUNSTRC" | grep frame_color | head -n1 | awk '{gsub(/"/,"",$3); print $3}')

# Check if an argument is provided
if [ $# -ne 1 ]; then
  echo "Usage: $0 up|down|mute|unmute|toggle"
  exit 1
fi

# Fixed notification ID for replacement
NOTIFY_ID=9999

# Perform the action based on the argument
if [ "$1" == "up" ]; then
  # Get the current volume as a floating point value (e.g., 1.00 for 100%)
  CURRENT_VOLUME=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2}')

  # Check if the volume is less than 1.00 (100%)
  if (( $(echo "$CURRENT_VOLUME < 1.00" | bc -l) )); then
    # Increase volume by 5%
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ &>/dev/null
  else
    echo "Volume is already at 100%"
  fi
elif [ "$1" == "upp" ]; then
  # Get the current volume as a floating point value (e.g., 1.00 for 100%)
  CURRENT_VOLUME=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2}')

  # Check if the volume is less than 1.00 (100%)
  if (( $(echo "$CURRENT_VOLUME < 1.00" | bc -l) )); then
    # Increase volume by 15%
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 15%+ &>/dev/null
  else
    echo "Volume is already at 100%"
  fi
elif [ "$1" == "down" ]; then
  # Decrease volume by 5%
  wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- &>/dev/null
elif [ "$1" == "downn" ]; then
  # Decrease volume by 15%
  wpctl set-volume @DEFAULT_AUDIO_SINK@ 15%- &>/dev/null
elif [ "$1" == "toggle" ]; then
  wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle &>/dev/null
elif [ "$1" == "mute" ]; then
  wpctl set-mute @DEFAULT_AUDIO_SINK@ 1 &>/dev/null
elif [ "$1" == "unmute" ]; then
  wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 &>/dev/null
else
  echo "Invalid argument. Use 'up' or 'down'."
  exit 1
fi

# Get the current volume again after adjusting
CURRENT_VOLUME=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2}')

# Convert the volume to a percentage and display it as a notification
CURRENT_VOLUME_PERCENT=$(echo "$CURRENT_VOLUME * 100" | bc -l)

# Mute state
VOLUME_INFO=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)
IS_MUTED=$(echo "$VOLUME_INFO" | grep -q MUTED && echo "yes" || echo "no")

# Display the current volume as a notification (without decimals)
if [ "$IS_MUTED" == "yes" ]; then
   dunstify -r "$NOTIFY_ID" \
     --hints=int:value:0 \
     -h string:hlcolor:"${HL_COLOR:-#888888}" \
     "Volume: Muted 🔇"
else
  dunstify -r "$NOTIFY_ID" \
    --hints=int:value:"$CURRENT_VOLUME_PERCENT" \
    -h string:hlcolor:"${HL_COLOR:-#888888}" \
    "Volume: $(printf "%.0f" "$CURRENT_VOLUME_PERCENT")%"
fi
