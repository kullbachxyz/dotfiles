#!/bin/bash

DUNSTRC="$HOME/.config/dunst/dunstrc"

# Extract foreground color from urgency_normal
HL_COLOR=$(grep -A5 "\[urgency_normal\]" "$DUNSTRC" | grep frame_color | head -n1 | awk '{gsub(/"/,"",$3); print $3}')
HL_COLOR=${HL_COLOR:-#888888}

# Check if an argument is provided
if [ $# -ne 1 ]; then
  echo "Usage: $0 up|down"
  exit 1
fi

BRIGHTNESS_CHANGE=5%
NOTIFY_ID=9998

# Perform the action
if [ "$1" == "up" ]; then
  brightnessctl set +$BRIGHTNESS_CHANGE &>/dev/null
elif [ "$1" == "down" ]; then
  brightnessctl set $BRIGHTNESS_CHANGE- &>/dev/null
else
  echo "Invalid argument. Use 'up' or 'down'."
  exit 1
fi

# Get brightness %
CURRENT_BRIGHTNESS=$(brightnessctl | awk -F'[()]' '{print $2}' | tr -d '%' | xargs)

# Notify
dunstify -r "$NOTIFY_ID" \
  --hints=int:value:"$CURRENT_BRIGHTNESS" \
  -h string:hlcolor:"$HL_COLOR" \
  "Brightness: ${CURRENT_BRIGHTNESS}%"
