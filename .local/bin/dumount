#!/bin/sh
# dumount - unmount USB drives using dmenu

# List mounted sd* partitions
DRIVES=$(lsblk -rno NAME,TYPE,SIZE,MOUNTPOINT | awk '$2=="part" && $4!="" && $1~/^sd/ {printf "/dev/%s (%s) at %s\n", $1, $3, $4}')

[ -z "$DRIVES" ] && notify-send "💽 Unmounter" "No mounted drives found." && exit 1

# Pick a drive
CHOSEN=$(echo "$DRIVES" | dmenu -p "Unmount drive:")
[ -z "$CHOSEN" ] && exit 0

# Extract the device path
DRIVE=$(echo "$CHOSEN" | awk '{print $1}')

# Ask for sudo password using -P (masked input)
PASSWORD=$(echo "" | dmenu -P -p "sudo password:")
[ -z "$PASSWORD" ] && exit 0

echo "$PASSWORD" | sudo -S umount "$DRIVE" 2>/tmp/dumount_err

if [ $? -eq 0 ]; then
    notify-send "💽 Unmounter" "✅ $DRIVE unmounted successfully."
else
    notify-send "💽 Unmounter" "❌ Failed to unmount $DRIVE: $(cat /tmp/dumount_err)"
fi
